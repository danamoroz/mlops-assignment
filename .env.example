# Copy to .env and fill in.

# HuggingFace token for model downloads.
HF_TOKEN=

# The model id you actually serve. Must match whatever you pass to vLLM
# via scripts/start_vllm.sh - if you serve an FP8 / AWQ / GPTQ variant,
# the model id here changes accordingly. The agent uses this for its
# chat-completions requests.
# --- Path A (Phase 4 local dev): hosted API — no local vLLM required ---
# Nebius Token Factory: https://tokenfactory.nebius.com
# VLLM_BASE_URL=https://api.tokenfactory.nebius.com/v1
# VLLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
# NEBIUS_API_KEY=
# Legacy Nebius AI Studio: VLLM_BASE_URL=https://api.studio.nebius.ai/v1
# OpenAI: VLLM_BASE_URL=https://api.openai.com/v1  VLLM_MODEL=gpt-4o-mini  OPENAI_API_KEY=

# --- H100 / local vLLM (submission) ---
VLLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# Langfuse keys — docker-compose headless-init seeds these on first boot.
# Or create your own project at http://localhost:3001 → Settings → API Keys.
LANGFUSE_PUBLIC_KEY=pk-lf-course-local-dev
LANGFUSE_SECRET_KEY=sk-lf-course-local-dev
LANGFUSE_HOST=http://localhost:3001
